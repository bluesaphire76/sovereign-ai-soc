# Sovereign AI SOC Docker demo configuration.
# Demo-only values: copy to deploy/demo/.env.demo and change them before use.
# Never reuse these values for production or commit a real environment file.

POSTGRES_USER=ai_soc_demo
POSTGRES_DB=ai_soc_demo
POSTGRES_PASSWORD=change-me-for-local-demo-only
AI_SOC_AUTH_SECRET=change-me-demo-auth-secret-at-least-32-characters

AI_SOC_API_PORT=8008
AI_SOC_FRONTEND_PORT=3000
QDRANT_HOST_PORT=6333
OLLAMA_HOST_PORT=11434

# This URL is embedded into the browser bundle during the frontend image build.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8008

QDRANT_COLLECTION=security_kb

# The demo profiles intentionally share one model to limit local disk/RAM use.
# Models are never downloaded automatically by Compose or CI.
OLLAMA_MODEL=qwen3.5:4b
AI_OLLAMA_MODEL=qwen3.5:4b
AI_SOC_LLM_FAST=qwen3.5:4b
AI_SOC_LLM_STANDARD=qwen3.5:4b
AI_SOC_LLM_QUALITY=qwen3.5:4b
