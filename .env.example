# Sovereign AI SOC backend/runtime configuration
# Copy this file to .env and set real values locally.
# Never commit real secrets.

WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_USER=admin
WAZUH_PASSWORD=<set-a-strong-wazuh-password>

WAZUH_BATCH_SIZE=150
WAZUH_WATERMARK_OVERLAP_SECONDS=15
WAZUH_INITIAL_LOOKBACK_MINUTES=60
WORKER_STALE_AFTER_SECONDS=300

# Legacy compatibility for older AI paths. Keep aligned with AI_SOC_LLM_STANDARD.
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_BASE_URL=http://localhost:11434

# AI SOC LLM model routing
AI_SOC_LLM_MODE=auto

# Fast model: lightweight, cheap, fallback
AI_SOC_LLM_FAST=llama3.2:3b
AI_SOC_LLM_FAST_NUM_CTX=2048
AI_SOC_LLM_FAST_TEMPERATURE=0.1
AI_SOC_LLM_FAST_TIMEOUT=20
AI_SOC_LLM_FAST_KEEP_ALIVE=30s

# Standard model: default operational model
AI_SOC_LLM_STANDARD=qwen3.5:4b
AI_SOC_LLM_STANDARD_NUM_CTX=4096
AI_SOC_LLM_STANDARD_TEMPERATURE=0.2
AI_SOC_LLM_STANDARD_TIMEOUT=45
AI_SOC_LLM_STANDARD_KEEP_ALIVE=2m

# Quality model: on-demand only, higher quality, do not keep in VRAM
AI_SOC_LLM_QUALITY=llama3.1:8b-instruct-q4_K_M
AI_SOC_LLM_QUALITY_NUM_CTX=4096
AI_SOC_LLM_QUALITY_TEMPERATURE=0.2
AI_SOC_LLM_QUALITY_TIMEOUT=90
AI_SOC_LLM_QUALITY_KEEP_ALIVE=0s

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aisoc
POSTGRES_USER=soc
POSTGRES_PASSWORD=<set-a-strong-postgres-password>

POLL_INTERVAL_SECONDS=30

# Local RAG / Qdrant knowledge base
AI_SOC_RAG_ENABLED=true
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=security_kb
QDRANT_KNOWLEDGE_BASE_PATH=knowledge_base
QDRANT_EMBEDDING_MODEL=sentence-transformers/multi-qa-MiniLM-L6-cos-v1
QDRANT_DEFAULT_LIMIT=4
QDRANT_TIMEOUT_SECONDS=2
QDRANT_CHUNK_MAX_CHARS=900
# Optional minimum similarity score. Leave empty to keep all returned Qdrant matches.
QDRANT_SCORE_THRESHOLD=

# Authentication signing secret.
# Minimum 32 characters. Prefer a generated random value.
# Example generation:
# python3 - <<'PY'
# import secrets
# print(secrets.token_urlsafe(48))
# PY
AI_SOC_AUTH_SECRET=<set-a-random-secret-at-least-32-chars>
AI_SOC_AUTH_TOKEN_TTL_SECONDS=28800



# Health observability thresholds
GRAFANA_URL=http://127.0.0.1:3002/grafana/
GRAFANA_HEALTH_URL=http://127.0.0.1:3002/grafana/api/health
PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_HEALTH_URL=http://127.0.0.1:9090/-/ready
ALERTMANAGER_URL=http://127.0.0.1:9093
ALERTMANAGER_HEALTH_URL=http://127.0.0.1:9093/-/ready
EVENT_SOURCE_WINDOW_MINUTES=15
EVENT_BACKLOG_WARN_THRESHOLD=50
EVENT_BACKLOG_ERROR_THRESHOLD=500
LATEST_INCIDENT_WARN_AFTER_SECONDS=900
LATEST_INCIDENT_ERROR_AFTER_SECONDS=3600

WAZUH_WATERMARK_FLUSH_EVERY=10
WAZUH_MAX_CATCHUP_MINUTES=30

# Event aggregation / deduplication
EVENT_AGGREGATION_WINDOW_MINUTES=15

# Correlation-first ingestion
CORRELATION_PRECHECK_WINDOW_MINUTES=15
CORRELATION_CREATE_INCIDENT_LEVEL=7
CORRELATION_RECENT_VOLUME_THRESHOLD=5
CORRELATION_AGGREGATE_COUNT_THRESHOLD=10

# Noise suppression policy
NOISE_SUPPRESSION_ENABLED=true
NOISE_SUPPRESSION_MAX_LEVEL=3
NOISE_SUPPRESSION_SAFE_SUDO_COMMAND_PREFIXES=/usr/bin/systemctl status,/usr/bin/journalctl,/usr/bin/systemctl restart ai-soc-api,/usr/bin/systemctl restart ai-soc-frontend,/usr/bin/systemctl restart ai-soc-worker

# Worker backlog / catch-up metrics
WORKER_REALTIME_MAX_LAG_SECONDS=120
WORKER_CATCHUP_MAX_LAG_SECONDS=900

# AI triage hardening
AI_TRIAGE_ENABLED=true
AI_TRIAGE_TIMEOUT_SECONDS=30
AI_TRIAGE_RETRY_ON_TIMEOUT=true
AI_TRIAGE_RETRY_TIMEOUT_SECONDS=15
AI_TRIAGE_COMPACT_RETRY_MAX_CHARS=3000
AI_TRIAGE_RETRY_ON_INVALID_OUTPUT=true
AI_TRIAGE_FALLBACK_ON_ERROR=true

# AI runtime health observability
AI_RUNTIME_HEALTH_TIMEOUT_SECONDS=3
AI_RUNTIME_HEALTH_CHAT_ENABLED=false
AI_RUNTIME_HEALTH_CHAT_TIMEOUT_SECONDS=20

# DB retention / cleanup policy
RETENTION_RAW_EVENTS_DAYS=90
RETENTION_SECURITY_ALERTS_DAYS=180
RETENTION_EVENT_AGGREGATES_DAYS=90
RETENTION_MAX_DELETE_ROWS=10000
RETENTION_REPORT_DIR=reports/retention
