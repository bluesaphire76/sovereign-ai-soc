# Sovereign AI SOC backend/runtime configuration
# Copy this file to .env and set real values locally.
# Never commit real secrets.

WAZUH_INDEXER_URL=https://localhost:9200
WAZUH_USER=admin
WAZUH_PASSWORD=<set-a-strong-wazuh-password>

WAZUH_BATCH_SIZE=150
WAZUH_WATERMARK_OVERLAP_SECONDS=15
WAZUH_INITIAL_LOOKBACK_MINUTES=60
WORKER_STALE_AFTER_SECONDS=300

OLLAMA_MODEL=qwen3:8b

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aisoc
POSTGRES_USER=soc
POSTGRES_PASSWORD=<set-a-strong-postgres-password>

POLL_INTERVAL_SECONDS=30

# Authentication signing secret.
# Minimum 32 characters. Prefer a generated random value.
# Example generation:
# python3 - <<'PY'
# import secrets
# print(secrets.token_urlsafe(48))
# PY
AI_SOC_AUTH_SECRET=<set-a-random-secret-at-least-32-chars>
AI_SOC_AUTH_TOKEN_TTL_SECONDS=28800



# Health observability thresholds
EVENT_SOURCE_WINDOW_MINUTES=15
EVENT_BACKLOG_WARN_THRESHOLD=50
EVENT_BACKLOG_ERROR_THRESHOLD=500
LATEST_INCIDENT_WARN_AFTER_SECONDS=900
LATEST_INCIDENT_ERROR_AFTER_SECONDS=3600

WAZUH_WATERMARK_FLUSH_EVERY=10
WAZUH_MAX_CATCHUP_MINUTES=30
