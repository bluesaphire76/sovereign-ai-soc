#!/usr/bin/env bash
set -euo pipefail

REPOSITORY_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"

show_help() {
  cat <<'EOF'
Sovereign AI SOC local CLI

Usage:
  ./ai-soc <command> [args]

Commands:
  init --profile <demo|local>    Create a safe local .env
  doctor [--strict] [--json]     Check local readiness
  validate                       Run public CI baseline validation
  validate-public-ci             Alias for validate
  validate-runtime [--strict] [--json]
                                 Check a running local runtime (read-only)
  demo-seed [--dry-run|--apply|--status] [--json]
                                 Manage synthetic local demo data
  version                        Show local repository/version information
  help                           Show this help

Planned future commands:
  demo-up
  demo-validate
  demo-down
EOF
}

resolve_python() {
  if [[ -x "$REPOSITORY_ROOT/.venv/bin/python" ]]; then
    printf '%s\n' "$REPOSITORY_ROOT/.venv/bin/python"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  else
    echo "Error: Python 3 is required but was not found." >&2
    return 1
  fi
}

show_version() {
  local branch="unknown"
  local commit="unknown"

  if command -v git >/dev/null 2>&1; then
    branch="$(
      git -C "$REPOSITORY_ROOT" branch --show-current 2>/dev/null || true
    )"
    commit="$(
      git -C "$REPOSITORY_ROOT" rev-parse --short HEAD 2>/dev/null || true
    )"
    branch="${branch:-unknown}"
    commit="${commit:-unknown}"
  fi

  printf '%s\n' \
    "Sovereign AI SOC local CLI" \
    "Repository: $REPOSITORY_ROOT" \
    "Git branch: $branch" \
    "Git commit: $commit"
}

command_name="${1:-help}"
if (( $# > 0 )); then
  shift
fi

case "$command_name" in
  help | --help | -h)
    show_help
    ;;
  init)
    python_bin="$(resolve_python)"
    exec "$python_bin" "$REPOSITORY_ROOT/scripts/init_env.py" "$@"
    ;;
  doctor)
    python_bin="$(resolve_python)"
    exec "$python_bin" "$REPOSITORY_ROOT/scripts/doctor.py" "$@"
    ;;
  validate | validate-public-ci)
    if (( $# > 0 )); then
      echo "Error: '$command_name' does not accept additional arguments." >&2
      exit 2
    fi
    python_bin="$(resolve_python)"
    exec "$python_bin" "$REPOSITORY_ROOT/scripts/validate_public_ci_baseline.py"
    ;;
  validate-runtime)
    python_bin="$(resolve_python)"
    exec "$python_bin" "$REPOSITORY_ROOT/scripts/validate_runtime.py" "$@"
    ;;
  demo-seed)
    python_bin="$(resolve_python)"
    exec "$python_bin" "$REPOSITORY_ROOT/scripts/demo_seed.py" "$@"
    ;;
  version)
    if (( $# > 0 )); then
      echo "Error: 'version' does not accept additional arguments." >&2
      exit 2
    fi
    show_version
    ;;
  *)
    echo "Error: unknown command '$command_name'." >&2
    echo >&2
    show_help >&2
    exit 2
    ;;
esac
