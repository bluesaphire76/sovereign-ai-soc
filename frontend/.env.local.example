# Sovereign AI SOC frontend configuration
# Copy this file to frontend/.env.local for local runtime.
# Never commit frontend/.env.local.

# Optional explicit synthetic-data banner. Off by default.
NEXT_PUBLIC_AI_SOC_DEMO_MODE=false

# When running behind Nginx:
NEXT_PUBLIC_API_BASE_URL=/api-backend

# When running frontend directly against backend during development:
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8008

# Optional: external Grafana URL for the ADMIN/ANALYST Observability link.
# For local Docker observability:
NEXT_PUBLIC_GRAFANA_URL=http://127.0.0.1:3002/grafana/d/ai-soc-platform-health/ai-soc-platform-health?orgId=1&refresh=30s
